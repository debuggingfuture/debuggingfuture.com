---
import BucketMap, { type Waypoint } from "../components/BucketMap.astro";
import SiteLayout from "../layouts/SiteLayout.astro";

// Edit these freely — `detail` is the mission log shown when a planet is opened.
// `star` names the destination after a real Yale Bright Star catalog star.
const waypoints: Waypoint[] = [
	{
		year: 2026,
		title: "CISSP",
		image: "/waypoints/cissp.jpg",
		star: "Bellatrix",
		detail:
			"Raise the shield grid: earn the CISSP certification and anchor the security credibility the rest of the work leans on.",
	},
	{
		year: 2026,
		title: "RAI",
		image: "/waypoints/rai.jpg",
		star: "Capella",
		detail:
			"Responsible AI milestone — build and certify the practice for trustworthy, safe AI systems.",
	},
	{
		year: 2026,
		title: "JP Biz Test",
		image: "/waypoints/jp-biz-test.jpg",
		star: "Rigel",
		detail: `Prep
- Morning Sat Video Playlist
- gengo 5h * 2
- Child song lists`,
	},
	{
		year: 2027,
		title: "SG Office Setup",
		image: "/waypoints/sg-office.jpg",
		star: "Procyon",
		detail:
			"Establish the Singapore outpost — the regional hub and legal base of operations.",
	},
	{
		year: 2028,
		title: "Japan Office",
		image: "/waypoints/japan-office.jpg",
		star: "Betelgeuse",
		detail:
			"Open the Japan office. Turn the earlier business test into a permanent presence.",
	},
];
---

<SiteLayout
	title="Work Voyage"
	description="An interstellar bucket-list map for my work — milestones to chart from 2026 to 2028."
	bare
>
	<BucketMap
		heading="Work Voyage 作"
		subheading="Every planet is a career milestone. Tap one for the mission briefing, then log your arrival to light the warp trail."
		storageKey="work"
		craft="🛰️"
		accent="#38bdf8"
		accentDeep="#0369a1"
		waypoints={waypoints}
	/>
</SiteLayout>
