---

<SiteLayout
	title="Bucket List"
	description="Two interstellar bucket-list voyage maps — life and work, in one place."
	bare
	noindex
>
	<div class="bucket">
		<div class="bucket-tabbar">
			<div class="bucket-tabs" role="tablist" aria-label="Choose a voyage">
				<button
					class="bt is-active"
					type="button"
					role="tab"
					id="tab-life"
					data-tab="life"
					aria-selected="true"
					aria-controls="panel-life"
				>
					<span class="bt-craft" aria-hidden="true">🚀</span>Life <span class="bt-zh">活</span>
				</button>
				<button
					class="bt"
					type="button"
					role="tab"
					id="tab-work"
					data-tab="work"
					aria-selected="false"
					aria-controls="panel-work"
					tabindex="-1"
				>
					<span class="bt-craft" aria-hidden="true">🛰️</span>Work <span class="bt-zh">作</span>
				</button>
			</div>
		</div>

		<div class="bucket-panel" id="panel-life" role="tabpanel" aria-labelledby="tab-life" data-panel="life">
			<BucketMap
				heading="Life Voyage 活"
				subheading="Every planet is a bucket-list destination. Tap one for the mission briefing, then log your arrival to light the warp trail."
				storageKey="life"
				craft="🚀"
				accent="#34d399"
				accentDeep="#0f766e"
				waypoints={lifeWaypoints}
			/>
		</div>

		<div class="bucket-panel" id="panel-work" role="tabpanel" aria-labelledby="tab-work" data-panel="work" hidden>
			<BucketMap
				heading="Work Voyage 作"
				subheading="Every planet is a career milestone. Tap one for the mission briefing, then log your arrival to light the warp trail."
				storageKey="work"
				craft="🛰️"
				accent="#38bdf8"
				accentDeep="#0369a1"
				waypoints={workWaypoints}
			/>
		</div>
	</div>
</SiteLayout>

<style>
	.bucket-tabbar {
		display: flex;
		justify-content: center;
		margin-bottom: 1.5rem;
	}
	.bucket-tabs {
		position: relative;
		z-index: 5;
		display: inline-flex;
		gap: 0.25rem;
		padding: 0.3rem;
		border-radius: 999px;
		background: rgba(10, 13, 24, 0.55);
		border: 1px solid rgba(150, 180, 255, 0.18);
		backdrop-filter: blur(10px) saturate(1.3);
		-webkit-backdrop-filter: blur(10px) saturate(1.3);
		box-shadow: 0 10px 34px rgba(0, 0, 0, 0.45), inset 0 1px 0 rgba(255, 255, 255, 0.08);
	}
	.bt {
		appearance: none;
		border: 0;
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.55rem 1.25rem;
		border-radius: 999px;
		background: transparent;
		color: rgba(234, 240, 255, 0.72);
		font-family: "BAUHAUS", "Noto Serif TC", system-ui, sans-serif;
		font-size: 1rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		transition: background 200ms ease, color 200ms ease, box-shadow 200ms ease;
	}
	.bt:hover { color: #fff; }
	.bt:focus-visible { outline: 2px solid rgba(255, 255, 255, 0.5); outline-offset: 2px; }
	.bt-craft { font-size: 1.1rem; }
	.bt-zh { opacity: 0.6; font-weight: 500; }
	.bt.is-active { background: rgba(255, 255, 255, 0.12); color: #fff; }
	.bt[data-tab="life"].is-active {
		box-shadow: inset 0 0 0 1px color-mix(in srgb, #34d399 55%, transparent),
			0 0 18px color-mix(in srgb, #34d399 28%, transparent);
	}
	.bt[data-tab="work"].is-active {
		box-shadow: inset 0 0 0 1px color-mix(in srgb, #38bdf8 55%, transparent),
			0 0 18px color-mix(in srgb, #38bdf8 28%, transparent);
	}
	.bucket-panel[hidden] { display: none; }

	@media (prefers-reduced-motion: reduce) {
		.bt { transition: none; }
	}
</style>

<script>
	(() => {
		const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>(".bt"));
		const panels = Array.from(document.querySelectorAll<HTMLElement>(".bucket-panel"));
		if (!tabs.length) return;

		const activate = (name: string, updateHash = true) => {
			tabs.forEach((t) => {
				const on = t.dataset.tab === name;
				t.classList.toggle("is-active", on);
				t.setAttribute("aria-selected", on ? "true" : "false");
				t.tabIndex = on ? 0 : -1;
			});
			panels.forEach((p) => {
				p.hidden = p.dataset.panel !== name;
			});
			if (updateHash) history.replaceState(null, "", `#${name}`);
		};

		const initial = location.hash.replace("#", "");
		activate(initial === "work" ? "work" : "life", false);

		tabs.forEach((t) => t.addEventListener("click", () => activate(t.dataset.tab || "life")));

		// Left/right arrow keys move between tabs (WAI-ARIA tablist pattern).
		const tablist = document.querySelector(".bucket-tabs");
		tablist?.addEventListener("keydown", (e) => {
			const ev = e as KeyboardEvent;
			if (ev.key !== "ArrowLeft" && ev.key !== "ArrowRight") return;
			ev.preventDefault();
			const active = tabs.findIndex((t) => t.classList.contains("is-active"));
			const next = ev.key === "ArrowRight" ? (active + 1) % tabs.length : (active - 1 + tabs.length) % tabs.length;
			activate(tabs[next].dataset.tab || "life");
			tabs[next].focus();
		});
	})();
</script>
