		detail: `Chart Fukuoka. Scout the Kyushu base — food, neighbourhoods, and the feel of everyday life on the ground.
- Visit mountain
- Visit Marine World Uminonakamichi`,
	},
	{
		year: 2028,
		title: "Japan Visa",
		image: "/waypoints/japan-visa.jpg",
		star: "Altair",
		detail:
			"Pass through the gateway: secure the right visa to live in Japan. The waypoint that unlocks everything after it.",
	},
	{
		year: 2028,
		title: "Australia Trip",
		image: "/waypoints/australia-trip.jpg",
		star: "Canopus",
		detail:
			"Cross into the southern skies — the red heart of Australia. Watch Uluru burn at sunset, and trade the northern constellations for Canopus overhead.",
	},
	{
		year: 2029,
		title: "Japan School",
		image: "/waypoints/japan-school.jpg",
		star: "Deneb",
		detail:
			"Enrol in school in Japan — language and study under the aurora. Turn visiting into belonging.",
	},
	{
		year: 2030,
		title: "Europe Trip",
		image: "/waypoints/europe-trip.jpg",
		star: "Arcturus",
		detail:
			"A proper voyage across the old-world systems of Europe. New cities, old streets, and a reset of perspective.",
	},
	{
		year: 2031,
		title: "Property",
		image: "/waypoints/property.jpg",
		star: "Polaris",
		detail:
			"Make planetfall for good — a place of my own. The final destination on this trajectory.",
	},
];

const workWaypoints: Waypoint[] = [
	{
		year: 2026,
		title: "CISSP",
		image: "/waypoints/cissp.jpg",
		star: "Bellatrix",
		detail:
			"Raise the shield grid: earn the CISSP certification and anchor the security credibility the rest of the work leans on.",
	},
	{
		year: 2026,
		title: "RAI",
		image: "/waypoints/rai.jpg",
		star: "Capella",
		detail:
			"Responsible AI milestone — build and certify the practice for trustworthy, safe AI systems.",
	},
	{
		year: 2026,
		title: "JP Biz Test",
		image: "/waypoints/jp-biz-test.jpg",
		star: "Rigel",
		detail: `Prep
- Morning Sat Video Playlist
- gengo 5h * 2
- Child song lists`,
	},
	{
		year: 2027,
		title: "SG Office Setup",
		image: "/waypoints/sg-office.jpg",
		star: "Procyon",
		detail:
			"Establish the Singapore outpost — the regional hub and legal base of operations.",
	},
	{
		year: 2028,
		title: "Japan Office",
