---
import BucketMap, { type Waypoint } from "../components/BucketMap.astro";
import SiteLayout from "../layouts/SiteLayout.astro";

// Direct-URL-only page: two voyage maps under one roof, toggled by the tabs.
// Not in the nav, noindex, and excluded from the sitemap.
// Edit `detail` freely — it's the mission log shown when a planet is opened.
// `star` names the destination after a real Yale Bright Star catalog star.
