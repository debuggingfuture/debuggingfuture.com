---
import { getEntry, render } from "astro:content";
import FormattedDate from "./FormattedDate.astro";

const { id } = Astro.props;

const post = await getEntry("life", id);
const { Content } = await render(post);
---

<div class="life-post">
	<p class="date">
		<FormattedDate date={post?.data.date} />
	</p>
	<h3 class="title">{post?.data.title}</h3>
	<div class="content">
		<Content />
	</div>
</div>

<style>
	.life-post .date {
		margin: 0 0 0.6rem;
		color: rgba(0, 0, 0, 0.55);
		font-size: 0.95rem;
		font-variant-numeric: tabular-nums;
	}
	.life-post .title {
		margin: 0 0 0.5rem;
		font-size: 1.5rem;
		font-weight: 600;
		line-height: 1.3;
	}
	.life-post .content {
		font-size: 1.25rem;
		line-height: var(--text-leading);
	}
	.life-post .content :global(img) {
		display: block;
		width: 100%;
		height: auto !important;
		max-height: 600px;
		object-fit: contain;
	}
</style>
