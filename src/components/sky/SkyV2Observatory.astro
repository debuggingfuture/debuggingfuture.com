---
// V2 — Observatory. Stellarium-fidelity sky:
//   • ~3000 stars from a baked HYG subset (mag ≤ 5.5)
//   • Milky Way band + galactic bulge concentration
//   • Atmospheric extinction (stars dim near horizon)
//   • Slow continuous rotation at sidereal rate
//   • Occasional shooting stars (suppressed during day)
//   • Constellation lines for the most legible stick figures
---

<div class="sky-v2" id="sky-v2-root" aria-hidden="true">
	<div class="sky-zenith"></div>
	<div class="sky-glow"></div>
	<div class="sky-haze"></div>
	<div class="sky-residual"></div>
	<svg class="milky-way" id="sky-milkyway-svg" preserveAspectRatio="xMidYMid slice" viewBox="0 0 1000 600">
		<defs>
			<filter id="mw-blur" x="-20%" y="-20%" width="140%" height="140%">
				<feGaussianBlur stdDeviation="14" />
			</filter>
			<filter id="mw-blur-tight" x="-20%" y="-20%" width="140%" height="140%">
				<feGaussianBlur stdDeviation="6" />
			</filter>
		</defs>
		<g id="mw-band" filter="url(#mw-blur)"></g>
		<g id="mw-bulge" filter="url(#mw-blur-tight)"></g>
	</svg>
	<svg class="stars" id="sky-stars-svg" preserveAspectRatio="xMidYMid slice" viewBox="0 0 1000 600">
		<defs>
			<filter id="star-glow" x="-50%" y="-50%" width="200%" height="200%">
				<feGaussianBlur stdDeviation="1.4" result="b" />
				<feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
			</filter>
			<radialGradient id="bright-star-halo" cx="50%" cy="50%" r="50%">
				<stop offset="0%"   stop-color="#ffffff" stop-opacity="0.45" />
				<stop offset="22%"  stop-color="#ffffff" stop-opacity="0.18" />
				<stop offset="55%"  stop-color="#ffffff" stop-opacity="0.05" />
				<stop offset="100%" stop-color="#ffffff" stop-opacity="0" />
			</radialGradient>
			<radialGradient id="bright-star-tint" cx="50%" cy="50%" r="50%">
				<stop offset="0%"   stop-color="currentColor" stop-opacity="0.35" />
				<stop offset="50%"  stop-color="currentColor" stop-opacity="0.08" />
				<stop offset="100%" stop-color="currentColor" stop-opacity="0" />
			</radialGradient>
		</defs>
		<g id="constellation-lines" class="constellation-lines"></g>
		<g id="star-points" class="star-points"></g>
		<g id="bright-star-points" class="bright-star-points"></g>
		<g id="star-labels" class="star-labels">
			<text id="spotlight-label" x="0" y="0" opacity="0"></text>
		</g>
	</svg>
	<div class="sun" id="sky-sun-v2"></div>
	<div class="moon" id="sky-moon-v2">
		<div class="moon-rotor" id="moon-rotor">
			<div class="moon-earthshine"></div>
			<div class="moon-disc"></div>
			<div class="moon-shadow" id="moon-shadow"></div>
		</div>
	</div>
</div>

<style>
	.sky-v2 {
		position: fixed;
		inset: 0;
		z-index: -10;
		pointer-events: none;
		overflow: hidden;
		background: var(--sky-zenith);
	}
	.sky-zenith {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to bottom,
			var(--sky-zenith) 0%,
			var(--sky-mid) 65%,
			var(--sky-horizon) 100%
		);
		transition: background 1500ms ease;
	}
	.sky-glow {
		position: absolute;
		inset: 0;
		background: radial-gradient(
			ellipse 100% 45% at var(--sun-x, 50%) 100%,
			var(--sky-glow),
			transparent 80%
		);
	}
	.sky-haze {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to bottom,
			transparent 0%,
			transparent 45%,
			rgba(50, 70, 110, 0.10) 75%,
			rgba(60, 80, 130, 0.20) 92%,
			rgba(80, 100, 150, 0.28) 100%
		);
		mix-blend-mode: screen;
		pointer-events: none;
	}
	.sky-residual {
		position: absolute;
		inset: 0;
		background: radial-gradient(
			ellipse 70% 22% at var(--sun-x, 50%) 102%,
			rgba(110, 130, 180, 0.18),
			transparent 60%
		);
		mix-blend-mode: screen;
		pointer-events: none;
	}
	.milky-way,
	.stars {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}
	.milky-way {
		opacity: calc(var(--star-visibility, 0) * 0.85);
		transition: opacity 1500ms ease;
		mix-blend-mode: screen;
	}
	.stars {
		opacity: var(--star-visibility, 0);
		transition: opacity 1500ms ease;
		filter: blur(0.25px);
	}
	.constellation-lines line {
		stroke: rgba(180, 200, 230, 0.16);
		stroke-width: 0.4;
		stroke-linecap: round;
	}
	.star-points circle {
		filter: url(#star-glow);
		animation: v2-twinkle var(--tw-dur, 4s) ease-in-out infinite;
		animation-delay: var(--tw-delay, 0s);
	}
	.bright-star-points circle.bright-halo {
		animation: v2-twinkle-bright var(--tw-dur, 7s) ease-in-out infinite;
		animation-delay: var(--tw-delay, 0s);
		mix-blend-mode: screen;
		transform-origin: center;
		transform-box: fill-box;
	}
	.bright-star-points circle.bright-tint {
		animation: v2-twinkle-tint var(--tw-dur, 6s) ease-in-out infinite;
		animation-delay: var(--tw-delay, 0s);
		mix-blend-mode: screen;
		transform-origin: center;
		transform-box: fill-box;
	}
	.bright-star-points circle.bright-core {
		filter: url(#star-glow);
		animation: v2-twinkle-core var(--tw-dur, 5s) ease-in-out infinite;
		animation-delay: var(--tw-delay, 0s);
	}
	@keyframes v2-twinkle-bright {
		0%, 100% { opacity: 0.85; transform: scale(1); }
		50%      { opacity: 0.55; transform: scale(0.9); }
	}
	@keyframes v2-twinkle-tint {
		0%, 100% { opacity: 0.7; }
		50%      { opacity: 0.4; }
	}
	@keyframes v2-twinkle-core {
		0%, 100% { opacity: 0.95; }
		50%      { opacity: 0.6; }
	}
	#spotlight-label {
		fill: rgba(235, 240, 250, 1);
		font: 8.5px/1 ui-sans-serif, system-ui, sans-serif;
		font-weight: 300;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		paint-order: stroke fill;
		pointer-events: none;
	}
	#spotlight-label.featuring {
		animation: feature-fade 6.4s linear forwards;
	}
	@keyframes feature-fade {
		0%   { opacity: 0; }
		18%  { opacity: 0.42; }
		78%  { opacity: 0.42; }
		100% { opacity: 0; }
	}
	@keyframes v2-twinkle {
		0%, 100% { opacity: 1; }
		50%      { opacity: 0.55; }
	}
	@media (prefers-reduced-motion: reduce) {
		.star-points circle { animation: none; }
		#spotlight-label.featuring { animation: none; opacity: 0.35; }
	}
	.sun {
		position: absolute;
		left: var(--sun-x, 50%);
		bottom: var(--sun-y, 50%);
		width: 110px;
		height: 110px;
		margin-left: -55px;
		margin-bottom: -55px;
		border-radius: 50%;
		background: radial-gradient(circle, #fff8df 0%, #ffd57a 50%, transparent 70%);
		opacity: var(--sun-opacity, 0);
		transition: opacity 700ms ease;
	}
	/* Pure-CSS realistic moon. Uses layered radial-gradients to fake maria,
	   craters, limb darkening and specular without an external image. */
	.moon {
		position: absolute;
		left: var(--moon-x, 80%);
		bottom: var(--moon-y, 50%);
		width: 72px;
		height: 72px;
		margin-left: -36px;
		margin-bottom: -36px;
		opacity: var(--moon-vis, 0);
		transition:
			opacity 900ms ease,
			left 1500ms cubic-bezier(0.4, 0, 0.2, 1),
			bottom 1500ms cubic-bezier(0.4, 0, 0.2, 1);
	}
	.moon::after {
		content: "";
		position: absolute;
		inset: -35%;
		border-radius: 50%;
		background: radial-gradient(
			circle,
			rgba(255, 225, 120, 0.28) 0%,
			rgba(255, 205, 80, 0.18) 22%,
			rgba(255, 190, 55, 0.08) 45%,
			transparent 65%
		);
		mix-blend-mode: screen;
		pointer-events: none;
	}
	.moon-rotor {
		position: absolute;
		inset: 0;
		transform: rotate(var(--moon-angle, 0deg));
	}
	.moon-disc,
	.moon-earthshine,
	.moon-shadow {
		position: absolute;
		inset: 0;
		border-radius: 50%;
	}
	.moon-earthshine {
		background: transparent;
	}
	.moon-disc {
		background:
			/* specular highlight (upper-left) */
			radial-gradient(circle at 30% 28%, rgba(255, 255, 245, 0.65) 0%, rgba(255, 255, 245, 0) 28%),
			/* maria — very soft, light warm patches */
			radial-gradient(circle at 60% 36%, rgba(200, 185, 155, 0.22) 0 8%,  transparent 16%),
			radial-gradient(circle at 38% 60%, rgba(195, 180, 150, 0.20) 0 11%, transparent 20%),
			radial-gradient(circle at 68% 64%, rgba(205, 190, 160, 0.18) 0 6%,  transparent 14%),
			radial-gradient(circle at 28% 38%, rgba(200, 185, 155, 0.16) 0 5%,  transparent 12%),
			radial-gradient(circle at 52% 72%, rgba(195, 180, 150, 0.18) 0 5%,  transparent 14%),
			radial-gradient(circle at 75% 50%, rgba(205, 190, 160, 0.14) 0 4%,  transparent 12%),
			/* tiny "crater" speckles */
			radial-gradient(circle at 22% 70%, rgba(255, 255, 240, 0.45) 0 1.5%, transparent 4%),
			radial-gradient(circle at 80% 32%, rgba(255, 255, 240, 0.35) 0 1%,   transparent 3%),
			radial-gradient(circle at 50% 22%, rgba(180, 160, 120, 0.25) 0 1%,   transparent 3%),
			/* limb darkening — very subtle warm rim */
			radial-gradient(circle at 50% 50%, transparent 65%, rgba(220, 195, 140, 0.30) 100%),
			/* base disc — bright white with a hint of warm at the rim */
			radial-gradient(circle at 38% 32%, #ffffff 0%, #fffaf0 55%, #fff2d0 85%, #f0dca8 100%);
	}
	.moon-shadow {
		background: rgba(15, 12, 28, 0.4);
		clip-path: var(--moon-clip, none);
		transition: clip-path 600ms ease, opacity 400ms ease;
	}
</style>

<script>
	import { renderStars, renderMilkyWay, renderMilkyWayBulge } from "../../astronomy/state";
	import { BRIGHT_STARS, CONSTELLATIONS } from "../../astronomy/stars";
	import { startShootingStars } from "../../astronomy/shooting-stars";

	const SVG_W = 1000;
	const SVG_H = 600;
	const linesEl = document.getElementById("constellation-lines") as unknown as SVGGElement;
	const starsEl = document.getElementById("star-points") as unknown as SVGGElement;
	const brightEl = document.getElementById("bright-star-points") as unknown as SVGGElement;
	const mwBandEl = document.getElementById("mw-band") as unknown as SVGGElement;
	const mwBulgeEl = document.getElementById("mw-bulge") as unknown as SVGGElement;
	const spotlightEl = document.getElementById("spotlight-label") as unknown as SVGTextElement;
	const root = document.getElementById("sky-v2-root") as HTMLDivElement;

	// Round-robin "featured" star cycle. Cycles through bright named stars
	// in magnitude order, skipping any not currently above the horizon.
	const FEATURE_LIST = BRIGHT_STARS
		.filter((s) => s.mag < 2.5)
		.slice()
		.sort((a, b) => a.mag - b.mag);
	const FEATURE_CYCLE_MS = 7400; // ~1s longer than the CSS animation
	let cycleIndex = -1;
	let featuredName: string | null = null;
	let lastVisibleByName: Record<string, { x: number; y: number; alt: number }> = {};

	function pickNext(): void {
		// Find the next bright named star that is currently visible above 8°.
		for (let i = 0; i < FEATURE_LIST.length; i++) {
			cycleIndex = (cycleIndex + 1) % FEATURE_LIST.length;
			const cand = FEATURE_LIST[cycleIndex];
			const pos = lastVisibleByName[cand.name];
			if (pos && pos.alt > 8) {
				featuredName = cand.name;
				spotlightEl.textContent = cand.name;
				// Restart CSS animation by toggling the class.
				spotlightEl.classList.remove("featuring");
				// Force reflow so the animation actually restarts.
				void (spotlightEl as unknown as HTMLElement).getBoundingClientRect();
				spotlightEl.classList.add("featuring");
				return;
			}
		}
		// No bright stars currently visible — clear the label.
		featuredName = null;
		spotlightEl.classList.remove("featuring");
		spotlightEl.textContent = "";
	}

	function updateSpotlightPosition(): void {
		if (!featuredName) return;
		const pos = lastVisibleByName[featuredName];
		if (!pos) return;
		spotlightEl.setAttribute("x", String(pos.x + 9));
		spotlightEl.setAttribute("y", String(pos.y + 4));
	}

	// Tick the cycle. Independent of the render cadence so the fade timing
	// stays smooth even if the sky redraws less often.
	function cycleTick() {
		if (document.visibilityState !== "visible") return;
		// Suppress when no bright stars are out (day / golden hour).
		if (Object.keys(lastVisibleByName).length === 0) return;
		pickNext();
	}
	// Kick off the first feature shortly after the first state arrives,
	// then continue at a steady cadence.
	setTimeout(cycleTick, 1800);
	setInterval(cycleTick, FEATURE_CYCLE_MS);

	function svgEl<K extends keyof SVGElementTagNameMap>(
		tag: K,
		attrs: Record<string, string | number>,
	): SVGElement {
		const el = document.createElementNS("http://www.w3.org/2000/svg", tag);
		for (const [k, v] of Object.entries(attrs)) el.setAttribute(k, String(v));
		return el;
	}

	// Build an SVG path string covering the dark side of the moon disc, in
	// pixel coordinates of the moon element. Used as a CSS clip-path on the
	// shadow overlay so the lit fraction shows through correctly at any phase.
	function darkSidePath(phase: number, illum: number, sizePx: number): string {
		const cx = sizePx / 2;
		const r = sizePx / 2;
		const rx = r * Math.abs(2 * illum - 1);
		const isWaxing = phase <= 0.5;
		const isCrescent = illum < 0.5;
		// Outer arc: left semicircle (sweep=0) for waxing, right (sweep=1) for waning.
		// Terminator arc: bulges toward the lit side for crescents (extends shadow),
		// toward the dark side for gibbous (cuts shadow).
		if (isWaxing) {
			return isCrescent
				? `M ${cx} 0 A ${r} ${r} 0 0 0 ${cx} ${sizePx} A ${rx} ${r} 0 0 1 ${cx} 0 Z`
				: `M ${cx} 0 A ${r} ${r} 0 0 0 ${cx} ${sizePx} A ${rx} ${r} 0 0 0 ${cx} 0 Z`;
		}
		return isCrescent
			? `M ${cx} 0 A ${r} ${r} 0 0 1 ${cx} ${sizePx} A ${rx} ${r} 0 0 0 ${cx} 0 Z`
			: `M ${cx} 0 A ${r} ${r} 0 0 1 ${cx} ${sizePx} A ${rx} ${r} 0 0 1 ${cx} 0 Z`;
	}

	function applyState(state: any): void {
		const r = document.documentElement;
		for (const [k, v] of Object.entries(state.cssVars as Record<string, string>)) {
			r.style.setProperty(k, v);
		}
		const az = state.sun.azimuth;
		let x = 50;
		if (az >= 90 && az <= 270) x = ((az - 90) / 180) * 100;
		else if (az < 90) x = -10;
		else x = 110;
		r.style.setProperty("--sun-x", `${x}%`);
		r.style.setProperty("--sun-y", `${Math.max(-10, Math.min(90, state.sun.altitude)) * 0.95}%`);
		r.style.setProperty("--sun-opacity", state.sun.altitude > -1 ? "1" : "0");

		// Moon: real altitude/azimuth from the engine.
		const mAz = state.moon.azimuth as number;
		const mAlt = state.moon.altitude as number;
		let mx = 50;
		if (mAz >= 90 && mAz <= 270) mx = ((mAz - 90) / 180) * 100;
		else if (mAz < 90) mx = -10;
		else mx = 110;
		r.style.setProperty("--moon-x", `${mx}%`);
		r.style.setProperty("--moon-y", `${Math.max(-10, Math.min(90, mAlt)) * 0.95}%`);
		// Moon visible above horizon at all phases (it can be up during the day too).
		// Daytime visibility is reduced because the bright sky outshines it.
		const moonAbove = mAlt > -1;
		const moonDayDim =
			state.sun.altitude > 6 ? 0.35 : state.sun.altitude > 0 ? 0.6 : 1;
		r.style.setProperty("--moon-vis", moonAbove ? String(moonDayDim) : "0");

		// Phase: a CSS clip-path on the shadow overlay gives the correct
		// crescent/quarter/gibbous shape for any phase. Coords in 0..72 to
		// match the moon element's pixel size.
		const phase = state.moon.phase as number;
		const illum = state.moon.illumination as number;
		const path = darkSidePath(phase, illum, 72);
		r.style.setProperty("--moon-clip", path ? `path("${path}")` : "circle(0%)");
		// Parallactic-angle rotation of the rotor so the bright limb aligns
		// with the actual sun direction in the (rotated) sky.
		const ang = state.moon.angle as number;
		r.style.setProperty("--moon-angle", `${(-ang).toFixed(1)}deg`);

		// Stars: HYG catalog, magnitude-cued, with extinction.
		const stars = renderStars(state, {
			facing: 180,
			fov: 240,
			catalog: "hyg",
			applyExtinction: true,
		});
		const nameToPos: Record<string, { x: number; y: number; visible: boolean }> = {};
		const visibleByName: Record<string, { x: number; y: number; alt: number }> = {};
		linesEl.replaceChildren();
		starsEl.replaceChildren();
		brightEl.replaceChildren();
		// Note: do NOT replaceChildren() on labelsEl — the persistent #spotlight-label
		// lives there and is updated by the round-robin cycle independently.

		for (const s of stars) {
			if (!s.visible || s.altitude < -1) continue;
			const px = s.x * SVG_W;
			const py = s.y * SVG_H;
			nameToPos[s.name] = { x: px, y: py, visible: true };
			if (s.altitude > 0) visibleByName[s.name] = { x: px, y: py, alt: s.altitude };

			// Magnitude → pixel radius. Cores are intentionally tiny — the
			// "size" of a bright star is meant to come from the soft gradient
			// halo, not from the disk itself.
			const isBright = s.mag < 2.0;
			const r = isBright
				? Math.max(0.35, 0.95 - s.mag * 0.18) // 0.35..0.95 px tight core
				: Math.max(0.18, 1.25 - s.mag * 0.22); // 0.2..1.05 px

			if (isBright) {
				// Soft white-to-transparent gradient — dominant size driver.
				const haloR = Math.max(5.5, 9.5 - s.mag * 1.6);
				const halo = svgEl("circle", {
					cx: px,
					cy: py,
					r: haloR,
					fill: "url(#bright-star-halo)",
				});
				const haloCs = halo as SVGElement & ElementCSSInlineStyle;
				haloCs.style.setProperty("--tw-dur", `${(6 + Math.random() * 5).toFixed(2)}s`);
				haloCs.style.setProperty("--tw-delay", `${(Math.random() * 5).toFixed(2)}s`);
				haloCs.classList.add("bright-halo");
				brightEl.appendChild(halo);

				// Subtle colored tint over the halo so the star carries its real
				// hue (Antares orange, Rigel blue) without becoming a disc.
				const tintR = Math.max(3.5, 6.0 - s.mag * 1.0);
				const tint = svgEl("circle", {
					cx: px,
					cy: py,
					r: tintR,
					fill: "url(#bright-star-tint)",
					color: s.color,
				});
				(tint as SVGElement).setAttribute("color", s.color);
				const tintCs = tint as SVGElement & ElementCSSInlineStyle;
				tintCs.style.setProperty("color", s.color);
				tintCs.style.setProperty("--tw-dur", `${(5 + Math.random() * 4).toFixed(2)}s`);
				tintCs.style.setProperty("--tw-delay", `${(Math.random() * 4).toFixed(2)}s`);
				tintCs.classList.add("bright-tint");
				brightEl.appendChild(tint);

				// Tight bright core on top.
				const core = svgEl("circle", { cx: px, cy: py, r, fill: "#fff" });
				const coreCs = core as SVGElement & ElementCSSInlineStyle;
				coreCs.style.setProperty("--tw-dur", `${(4 + Math.random() * 3).toFixed(2)}s`);
				coreCs.style.setProperty("--tw-delay", `${(Math.random() * 3).toFixed(2)}s`);
				coreCs.classList.add("bright-core");
				brightEl.appendChild(core);
			} else {
				const c = svgEl("circle", { cx: px, cy: py, r, fill: s.color });
				const cs = c as SVGElement & ElementCSSInlineStyle;
				cs.style.setProperty("--tw-dur", `${(2 + Math.random() * 5).toFixed(2)}s`);
				cs.style.setProperty("--tw-delay", `${(Math.random() * 5).toFixed(2)}s`);
				starsEl.appendChild(c);
			}
		}

		// Constellation lines (keyed off the curated bright-star names).
		for (const segs of Object.values(CONSTELLATIONS)) {
			for (const [a, b] of segs) {
				const pa = nameToPos[a];
				const pb = nameToPos[b];
				if (!pa || !pb || !pa.visible || !pb.visible) continue;
				linesEl.appendChild(svgEl("line", { x1: pa.x, y1: pa.y, x2: pb.x, y2: pb.y }));
			}
		}

		// Update visible-stars map for the spotlight cycler and re-anchor the
		// current featured label so it tracks the slow sky drift.
		lastVisibleByName = visibleByName;
		updateSpotlightPosition();

		// Milky Way: faint band + denser bulge concentration.
		mwBandEl.replaceChildren();
		mwBulgeEl.replaceChildren();
		const band = renderMilkyWay(state, { facing: 180, fov: 240 });
		for (const p of band) {
			if (!p.visible) continue;
			mwBandEl.appendChild(
				svgEl("circle", {
					cx: p.x * SVG_W,
					cy: p.y * SVG_H,
					r: 16,
					fill: `rgba(220, 220, 240, ${(p.intensity * 0.18).toFixed(3)})`,
				}),
			);
		}
		const bulge = renderMilkyWayBulge(state, { facing: 180, fov: 240 });
		for (const p of bulge) {
			if (!p.visible) continue;
			mwBulgeEl.appendChild(
				svgEl("circle", {
					cx: p.x * SVG_W,
					cy: p.y * SVG_H,
					r: 7,
					fill: `rgba(240, 235, 220, ${(p.intensity * 0.22).toFixed(3)})`,
				}),
			);
		}
	}

	let lastTwilight: string | undefined;
	let currentTwilight: string | undefined;

	document.addEventListener("skystate", (e: Event) => {
		const state = (e as CustomEvent).detail;
		currentTwilight = state.twilight;
		applyState(state);
	});

	// Shooting stars: more often at night, suppressed during day/golden hour.
	startShootingStars({
		container: root,
		intervalSeconds: 22,
		length: 22,
		color: "#ffffff",
		enabled: () =>
			currentTwilight !== "day" && currentTwilight !== "goldenHour",
	});
</script>
